generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ============================================================================
// USER & AUTH
// ============================================================================

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("STAFF") // SUPER_ADMIN, ADMIN_GUDANG, SUPERVISOR, STAFF, AUDITOR, VIEWER
  avatar    String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  stockOpnames  StockOpname[]
  inbounds      Inbound[]
  outbounds     Outbound[]
  transfers     Transfer[]
}

// ============================================================================
// INVENTORY CORE
// ============================================================================

model Category {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items Item[]
}

model Location {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  type      String   @default("GUDANG") // GUDANG, RAK, COLD_STORAGE, LOADING_DOCK
  capacity  Int      @default(100)
  used      Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         Item[]
  stockOpnames  StockOpname[]
  transfersFrom Transfer[]    @relation("FromLocation")
  transfersTo   Transfer[]    @relation("ToLocation")
}

model Item {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  categoryId  String
  locationId  String
  stock       Int      @default(0)
  minStock    Int      @default(10)
  unit        String   @default("pcs") // pcs, kg, liter, box, roll, meter, set
  price       Float    @default(0)
  weight      Float?
  status      String   @default("TERSEDIA") // TERSEDIA, STOK_RENDAH, HABIS
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category       Category         @relation(fields: [categoryId], references: [id])
  location       Location         @relation(fields: [locationId], references: [id])
  inboundItems   InboundItem[]
  outboundItems  OutboundItem[]
  transferItems  TransferItem[]
  opnameItems    StockOpnameItem[]
}

// ============================================================================
// SUPPLIER
// ============================================================================

model Supplier {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  city          String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inbounds Inbound[]
}

// ============================================================================
// INBOUND (BARANG MASUK)
// ============================================================================

model Inbound {
  id         String   @id @default(cuid())
  poNumber   String   @unique
  date       DateTime @default(now())
  supplierId String
  status     String   @default("PENDING") // PENDING, DITERIMA, DIPERIKSA, DISIMPAN
  receiverId String?
  notes      String?
  totalValue Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  supplier Supplier      @relation(fields: [supplierId], references: [id])
  receiver User?         @relation(fields: [receiverId], references: [id])
  items    InboundItem[]
}

model InboundItem {
  id        String @id @default(cuid())
  inboundId String
  itemId    String
  quantity  Int
  price     Float

  inbound Inbound @relation(fields: [inboundId], references: [id], onDelete: Cascade)
  item    Item    @relation(fields: [itemId], references: [id])
}

// ============================================================================
// OUTBOUND (BARANG KELUAR)
// ============================================================================

model Outbound {
  id          String   @id @default(cuid())
  soNumber    String   @unique
  date        DateTime @default(now())
  destination String
  status      String   @default("PENDING") // PENDING, DISETUJUI, DIKEMAS, DIKIRIM
  shipperId   String?
  notes       String?
  totalValue  Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shipper User?          @relation(fields: [shipperId], references: [id])
  items   OutboundItem[]
}

model OutboundItem {
  id         String @id @default(cuid())
  outboundId String
  itemId     String
  quantity   Int
  price      Float

  outbound Outbound @relation(fields: [outboundId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])
}

// ============================================================================
// TRANSFER ANTAR LOKASI
// ============================================================================

model Transfer {
  id             String   @id @default(cuid())
  transferNumber String   @unique
  date           DateTime @default(now())
  fromLocationId String
  toLocationId   String
  status         String   @default("PENDING") // PENDING, DIPROSES, SELESAI
  transferById   String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fromLocation Location       @relation("FromLocation", fields: [fromLocationId], references: [id])
  toLocation   Location       @relation("ToLocation", fields: [toLocationId], references: [id])
  transferBy   User?          @relation(fields: [transferById], references: [id])
  items        TransferItem[]
}

model TransferItem {
  id         String @id @default(cuid())
  transferId String
  itemId     String
  quantity   Int

  transfer Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  item     Item     @relation(fields: [itemId], references: [id])
}

// ============================================================================
// STOCK OPNAME / AUDIT
// ============================================================================

model StockOpname {
  id           String   @id @default(cuid())
  opnameNumber String   @unique
  date         DateTime @default(now())
  locationId   String
  status       String   @default("DRAFT") // DRAFT, DALAM_PROSES, SELESAI, DISETUJUI
  auditorId    String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  location Location          @relation(fields: [locationId], references: [id])
  auditor  User?             @relation(fields: [auditorId], references: [id])
  items    StockOpnameItem[]
}

model StockOpnameItem {
  id            String @id @default(cuid())
  stockOpnameId String
  itemId        String
  systemStock   Int
  physicalStock Int
  difference    Int    @default(0)
  notes         String?

  stockOpname StockOpname @relation(fields: [stockOpnameId], references: [id], onDelete: Cascade)
  item        Item        @relation(fields: [itemId], references: [id])
}

// ============================================================================
// NOTIFICATION
// ============================================================================

model Notification {
  id        String   @id @default(cuid())
  type      String   @default("INFO") // INFO, WARNING, SUCCESS, ERROR, STOCK, TRANSACTION
  title     String
  message   String
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
